{
  "manifest_version": 3,
  "name": "Abhimo Tracker -- Website Activity",
  "version": "0.1.0",
  "description": "Records the domain of the active browser tab during working hours, for the same backend the Abhimo desktop tray app already reports to. Domain only -- no page content, no full URLs, no browsing history is ever read.",
  "key": "",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Abhimo Tracker"
  },
  "minimum_chrome_version": "109",
  "externally_connectable": {
    "matches": [
      "http://127.0.0.1:8090/*",
      "http://localhost:8090/*"
    ]
  }
}