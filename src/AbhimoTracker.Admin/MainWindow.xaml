<Window x:Class="AbhimoTracker.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Abhimo Admin" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <!-- No URL bar, no browser chrome: just the WebView2 surface filling
         the window, per the master prompt's "no browser opened at any
         point" requirement. -->
    <Grid>
        <wv2:WebView2 x:Name="Browser"/>
    </Grid>
</Window>
